{
  "name": "proofpay-hedera-x402",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aitrailblazer/proofpay-hedera-x402.git"
  },
  "homepage": "https://github.com/aitrailblazer/proofpay-hedera-x402#readme",
  "keywords": [
    "hedera",
    "x402",
    "agents",
    "payments",
    "receipts",
    "deltasignal"
  ],
  "description": "Pay for deterministic issuer evidence on Hedera and receive a cryptographically bound proof receipt.",
  "scripts": {
    "build": "tsc --noEmit",
    "check:public": "node scripts/check-public-distribution.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "start:prod": "node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "keygen": "tsx scripts/generate-receipt-key.ts",
    "buy": "tsx scripts/buy.ts",
    "configure:keychain": "bash scripts/configure-keychain.sh",
    "demo:keychain": "bash scripts/demo-keychain.sh",
    "demo:keyvault": "bash scripts/demo-keyvault.sh",
    "demo:live": "bash scripts/demo-live.sh",
    "demo:frames": "tsx scripts/render-demo-frames.ts",
    "demo:video": "tsx scripts/build-demo-video.ts",
    "demo:tamper": "tsx scripts/tamper-demo.ts",
    "verify": "tsx scripts/verify.ts",
    "check": "npm run check:public && npm run build && npm test"
  },
  "engines": {
    "node": ">=20.18.3"
  },
  "dependencies": {
    "@hono/node-server": "2.0.11",
    "@x402/core": "2.19.0",
    "@x402/fetch": "2.19.0",
    "@x402/hedera": "2.19.0",
    "@x402/hono": "2.19.0",
    "dotenv": "16.6.1",
    "hono": "4.12.31"
  },
  "devDependencies": {
    "@types/node": "22.19.1",
    "playwright-core": "^1.55.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "@grpc/grpc-js": "1.12.7",
    "@hiero-ledger/sdk": "2.86.2",
    "protobufjs": "8.7.1",
    "ws": "8.21.1"
  }
}
